PORT=3000
HOST=0.0.0.0

# HALLAYM AI
# Agar Groq ishlatsangiz shu yerga Groq API key qo'ying.
HALLAYM_API_KEY=PASTE_YOUR_HALLAYM_OR_GROQ_API_KEY_HERE
HALLAYM_TEXT_MODEL=llama-3.3-70b-versatile
HALLAYM_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Cloudinary
CLOUDINARY_CLOUD_NAME=PASTE_YOUR_CLOUD_NAME_HERE
CLOUDINARY_API_KEY=PASTE_YOUR_CLOUDINARY_API_KEY_HERE
CLOUDINARY_API_SECRET=PASTE_YOUR_CLOUDINARY_API_SECRET_HERE
# Agar unsigned preset ishlatsangiz mana buni to'ldiring va API key/secret o'rniga ishlatishingiz mumkin:
# CLOUDINARY_UPLOAD_PRESET=PASTE_YOUR_UPLOAD_PRESET_HERE
CLOUDINARY_FOLDER=aishelf

# MongoDB
MONGODB_URI=mongodb+srv://abumafia0:abumafia0@abumafia.h1trttg.mongodb.net/ais?appName=abumafia
MONGODB_DATABASE=ais

# ExpressTURN
# Dashboard'dagi TURN host(lar), username va password bilan to'ldiring.
# Bir nechta host bo'lsa vergul bilan yozing.
EXPRESSTURN_HOST=PASTE_EXPRESSTURN_HOST_HERE
EXPRESSTURN_PORT=3478
EXPRESSTURN_TURNS_PORT=443
EXPRESSTURN_USERNAME=PASTE_EXPRESSTURN_USERNAME_HERE
EXPRESSTURN_PASSWORD=PASTE_EXPRESSTURN_PASSWORD_HERE
EXPRESSTURN_ENABLE_TURNS=true

# Admin
ADMIN_EMAIL=admin@aishelf.local
ADMIN_PASSWORD=ChangeThisAdmin123!
